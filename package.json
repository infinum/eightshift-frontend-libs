{
	"name": "@eightshift/frontend-libs",
	"version": "16.0.0",
	"description": "A collection of useful frontend utility modules. powered by Eightshift",
	"author": {
		"name": "Eightshift team",
		"email": "team@eightshift.com",
		"url": "https://eightshift.com/"
	},
	"repository": {
